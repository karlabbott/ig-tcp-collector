      {
        "id": 1,
        "title": "Total TCP Drops",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Log Analytics",
            "azureLogAnalytics": {
              "query": "TraceTcpDrop_CL\n| where $__timeFilter(TimeGenerated)\n| summarize Count=count()",
              "resources": ["__LAW_RESOURCE_ID__"]
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 100 }
              ]
            },
            "color": { "mode": "thresholds" },
            "mappings": []
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
